# Jarvis environment configuration (template)
#
# Copy this file to ~/.jarvis.env and edit the values you care about:
#
#     cp .env.example ~/.jarvis.env
#
# ~/.jarvis.env is the default path the Python worker reads at startup
# (JARVIS_ENV_FILE below overrides it). Lines are simple KEY=VALUE assignments;
# `export KEY=VALUE` also works, and values with spaces must be quoted.
# Everything here has a sensible default EXCEPT where marked REQUIRED, so a copy
# with only the keys you need uncommented is fine. Do not commit your filled-in
# ~/.jarvis.env — it may hold secrets.
#
# NOTE: A few Codex-tier and identity settings are still being added to
# jarvis/config.py in parallel; re-grep config.py / tools.py for the freshest
# list if a newer Codex feature seems undocumented here.

# ---------------------------------------------------------------------------
# Where the worker loads env from
# ---------------------------------------------------------------------------
# JARVIS_ENV_FILE=~/.jarvis.env          # Path to this env file (default shown)

# ---------------------------------------------------------------------------
# Identity / branding (optional)
# ---------------------------------------------------------------------------
# JARVIS_USER_NAME=                       # Your name, used to personalize replies. Empty = generic "you".
# JARVIS_BUNDLE_ID=local.leo.jarvis       # macOS bundle id the worker expects; match your built .app's BUNDLE_ID.

# ---------------------------------------------------------------------------
# Cloud model API keys (optional — only for cloud backends)
# ---------------------------------------------------------------------------
# GROQ_API_KEY is REQUIRED only if you point a model backend at "groq"
# (see JARVIS_FAST_MODEL_BACKEND / *_FALLBACK_BACKEND / *_EMAIL_SUMMARY_BACKEND).
# The out-of-the-box backends are all local Ollama, so this can stay empty.
# Get a key from https://console.groq.com/keys
GROQ_API_KEY=
# JARVIS_GROQ_BASE_URL=https://api.groq.com/openai/v1   # Groq OpenAI-compatible endpoint.
# JARVIS_GROQ_MODEL=llama-3.3-70b-versatile             # Groq model used when a backend is "groq".

# ---------------------------------------------------------------------------
# Model backends and names (optional; defaults use local Ollama)
# ---------------------------------------------------------------------------
# JARVIS_FAST_MODEL_BACKEND=ollama                # "ollama" or "groq" for the fast planning model.
# JARVIS_FAST_MODEL=qwen3:0.6b                    # Ollama model name for the fast tier (ollama pull this).
# JARVIS_FAST_MODEL_FALLBACK_BACKEND=ollama       # Backend used if the primary fast model fails.
# JARVIS_FAST_MODEL_FALLBACK_ENABLED=true         # Enable the fast-model fallback path.
# JARVIS_FAST_MODEL_TIMEOUT_SECONDS=5             # Per-call timeout for the fast model (1-15).
# JARVIS_FAST_MODEL_MAX_TOKENS=80                 # Max output tokens for the fast model (16-256).
# JARVIS_MIDDLE_MODEL=gpt-oss:120b-cloud          # Larger reasoning model (Ollama cloud model by default).
# JARVIS_MIDDLE_MODEL_TIMEOUT_SECONDS=18          # Per-call timeout for the middle model (4-60).
# JARVIS_MIDDLE_MODEL_MAX_TOKENS=420              # Max output tokens for the middle model (80-1200).

# ---------------------------------------------------------------------------
# Ollama (optional; needed for the local model backends above)
# ---------------------------------------------------------------------------
# JARVIS_OLLAMA_BASE_URL=http://127.0.0.1:11434   # Local Ollama server URL.
# JARVIS_OLLAMA_AUTOSTART=true                    # Start `ollama serve` automatically if it is offline.
# JARVIS_OLLAMA_STARTUP_TIMEOUT_SECONDS=6         # How long to wait for Ollama to come up (1-20).

# ---------------------------------------------------------------------------
# Codex CLI delegation (optional; requires `codex login`, not an API key)
# ---------------------------------------------------------------------------
# JARVIS_CODEX_MODEL=gpt-5.4-mini                 # Model the Codex CLI runs for delegated coding jobs.
# JARVIS_CODEX_REASONING_EFFORT=low               # Codex reasoning effort (low/medium/high).
# JARVIS_CODEX_TIMEOUT_SECONDS=210                # Timeout for background Codex jobs (10-300).
# JARVIS_CODEX_CHAT_TIMEOUT_SECONDS=12            # Timeout for short interactive Codex chat (3-90).
# JARVIS_CODEX_WRITE_ENABLED=true                 # Allow the write-capable Codex tier (still confirmation-gated).
# JARVIS_CODEX_CHAT_REGISTRY=<runtime>/codex_chats.json         # Where Codex chat sessions are tracked.
# JARVIS_CODEX_DAILY_MEMORY=<runtime>/codex_daily_memory.json   # Where Codex daily memory is stored.
# JARVIS_CODEX_PROXY_MODE=auto                    # Codex network proxy mode (auto/on/off-style handling in tools.py).
# JARVIS_CODEX_LOCAL_PROXY_HOST=127.0.0.1         # Host for the optional local Codex proxy.
# JARVIS_CODEX_LOCAL_PROXY_PORT=7890              # Port for the optional local Codex proxy.

# ---------------------------------------------------------------------------
# Text-to-speech (optional)
# ---------------------------------------------------------------------------
# JARVIS_APP_VOICE_DEFAULTS=false                 # When true, turn on automatic speech + spoken status by default.
# JARVIS_TTS_AUTOMATIC_ENABLED=<app_voice_defaults>   # Speak replies automatically.
# JARVIS_TTS_SPEAK_STATUS=<app_voice_defaults>        # Speak status/diagnostic summaries.
# JARVIS_TTS_PROVIDER=macos                        # "macos" (built-in `say`) or "piper".
# JARVIS_TTS_FALLBACK_PROVIDER=macos               # Provider used if the primary TTS provider fails.
# JARVIS_TTS_PLAIN_SAY=true                         # Use the plain macOS `say` voice (ignores voice/rate below).
# JARVIS_TTS_VOICE=                                 # macOS voice name (only when JARVIS_TTS_PLAIN_SAY=false).
# JARVIS_TTS_RATE=0                                 # macOS speech rate 80-280 (only when JARVIS_TTS_PLAIN_SAY=false).
# JARVIS_TTS_MAX_CHARS=900                          # Max characters spoken per utterance (80-2400).
# JARVIS_TTS_AFPLAY=/usr/bin/afplay                 # Audio player used for synthesized WAV output.
# JARVIS_TTS_REQUIRE_EMERGENCY_CONTROL=false        # Require emergency-control gate before speaking.
#
# Piper neural TTS (only used when JARVIS_TTS_PROVIDER=piper):
# JARVIS_TTS_PIPER_MODEL=<runtime>/tts_models/piper/en_US-ryan-high.onnx   # Path to the Piper .onnx voice model.
# JARVIS_TTS_PIPER_CONFIG=<model>.json              # Path to the Piper model JSON (defaults to <model>.json).
# JARVIS_TTS_PIPER_BIN=                             # Path to the piper binary (empty = look up on PATH).
# JARVIS_TTS_PIPER_ESPEAK_DATA=~/.jarvis/tts/piper/espeak-ng-data   # espeak-ng data dir for Piper phonemes.
# JARVIS_TTS_PIPER_LABEL="Piper Ryan high American male"            # Human-readable label for the Piper voice.
# JARVIS_TTS_PIPER_TIMEOUT_SECONDS=8                # Piper synthesis timeout (1-30).
# JARVIS_TTS_PIPER_WARM_WORKER=true                 # Keep a warm Piper worker for lower latency.
# JARVIS_TTS_PIPER_WARMUP_TIMEOUT_SECONDS=2         # Warmup timeout for the Piper worker (0-15).
# JARVIS_TTS_PIPER_LENGTH_SCALE=0.85               # Piper length scale / speaking speed (0.5-1.4).

# ---------------------------------------------------------------------------
# Local server / networking (optional)
# ---------------------------------------------------------------------------
# JARVIS_HOST=127.0.0.1                            # Bind host for the local dashboard/worker.
# JARVIS_PORT=8765                                 # Bind port (1-65535).
# JARVIS_START_PAUSED=false                        # Start in Paused mode (no command execution).
# JARVIS_ALLOW_NON_LOOPBACK=false                  # Allow binding non-loopback hosts (e.g. 0.0.0.0). Keep false.

# ---------------------------------------------------------------------------
# Audit log (optional)
# ---------------------------------------------------------------------------
# JARVIS_AUDIT_RETENTION_DAYS=90                   # Days of audit history to retain (min 1).
# JARVIS_AUDIT_MAX_BYTES=1073741824                # Max audit log size in bytes (default 1 GiB).

# ---------------------------------------------------------------------------
# Email / Outlook (optional)
# ---------------------------------------------------------------------------
# JARVIS_EMAIL_SUMMARY_BACKEND=ollama              # Backend for email summaries ("ollama" or "groq").
# JARVIS_EMAIL_SUMMARY_MODEL=<fast_model>          # Model for email summaries (defaults to the fast model).
# JARVIS_EMAIL_SUMMARY_TIMEOUT_SECONDS=8           # Email summary timeout (2-30).
# JARVIS_EMAIL_SUMMARY_MAX_INPUT_CHARS=3200        # Max input characters fed to the summarizer (500-12000).
# JARVIS_EMAIL_SUMMARY_MAX_TOKENS=180              # Max output tokens for email summaries (48-512).
# JARVIS_EMAIL_DEFAULT_SCAN_MESSAGES=5             # Default number of inbox messages to scan (1-25).
# JARVIS_OUTLOOK_MAX_SCAN_MESSAGES=250             # Max Outlook messages to scan (10-2000).
# JARVIS_OUTLOOK_APPLESCRIPT_TIMEOUT_SECONDS=20    # Outlook AppleScript timeout (5-90).
# JARVIS_OUTLOOK_OCR_TIMEOUT_SECONDS=30            # Outlook screen-OCR timeout (5-90).
# JARVIS_OUTLOOK_USE_APPLESCRIPT=false             # Use AppleScript to read Outlook instead of OCR.
# JARVIS_OUTLOOK_USE_LEGACY_SQLITE=false           # Use the legacy Outlook SQLite reader.

# ---------------------------------------------------------------------------
# LocalOS Music bridge / Calendar (optional; feature-specific)
# ---------------------------------------------------------------------------
# JARVIS_MUSIC_APP_BRIDGE_URL=http://127.0.0.1:47879                          # LocalOS Music control bridge URL.
# JARVIS_MUSIC_APP_BRIDGE_TOKEN_FILE="~/Library/Application Support/Music/control-token.txt"  # Music bridge auth token file.
# JARVIS_MUSIC_APP_BRIDGE=                          # Override to force-enable/disable the music bridge.
# JARVIS_MUSIC_APP_PATH=<repo>/../Music App/dist/Music.app                    # Path to the LocalOS Music.app.
# JARVIS_LEGACY_LOCALOS_MUSIC_FALLBACK=             # Force the legacy LocalOS music fallback path.
# JARVIS_CALENDAR_APPLESCRIPT_FALLBACK=false        # Allow AppleScript fallback for calendar reads.

# ---------------------------------------------------------------------------
# Worker / bundle internals (normally set automatically by the macOS app)
# ---------------------------------------------------------------------------
# You usually should NOT set these by hand; the packaged .app passes them to the
# worker so diagnostics can report the enclosing bundle. Listed for completeness.
# JARVIS_WORKSPACE_ROOT=<repo root>                 # Overrides the detected project root.
# JARVIS_WORKER_APP_PATH=                           # Path of the .app that launched the worker.
# JARVIS_WORKER_BUNDLE_ID=                          # Bundle id of the launching .app.
# JARVIS_WORKER_BUNDLE_VERSION=                     # Short version string of the launching .app.
# JARVIS_WORKER_BUNDLE_BUILD=                       # Build number of the launching .app.
#
# Read by the Swift menu-bar shell (not the Python worker), documented here for reference:
# JARVIS_DISABLE_WORKER_AUTOSTART=1                 # Stop the menu-bar app from auto-starting the worker.
# JARVIS_PROJECT_ROOT=/path/to/Jarvis               # Project root when launching the shell outside the repo.
# JARVIS_BASE_URL=http://127.0.0.1:8765             # Worker URL the Swift shell/clients talk to (JARVIS_URL also works).
